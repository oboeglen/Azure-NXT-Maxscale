# =============================================================================
# signaling.conf.example — nextcloud-spreed-signaling configuration template
# Copy to signaling.conf and fill in your values, OR let deploy.sh generate it.
# Full reference: https://github.com/strukturag/nextcloud-spreed-signaling
# =============================================================================

[http]
# Listen on all interfaces — HAProxy proxies inbound requests
listen = :8080

[app]
debug = false
# Trust HAProxy IPs (talk-net subnet) so X-Real-IP forwarding works correctly
trustedproxies = 172.60.0.0/24

[sessions]
# hashkey: 32 or 64 bytes hex — signs session tokens
hashkey = REPLACE_WITH_64_HEX_CHARS
# blockkey: MUST be 16, 24 or 32 bytes hex — encrypts session payload
blockkey = REPLACE_WITH_32_HEX_CHARS

[clients]
# internalsecret: for internal services (SIP bridge etc.)
# Must be DIFFERENT from the backend secret below
internalsecret = REPLACE_WITH_INTERNAL_HEX_SECRET

[backend]
# Comma-separated list of backend section identifiers
backends = nc
# HTTP timeout for Nextcloud backend calls (seconds)
timeout = 10
connectionsperhost = 8

# Backend section name must match the identifier above — no "backend " prefix, no quotes
[nc]
# urls: comma-separated list of Nextcloud instance URLs (no trailing slash)
urls = https://nextcloud.example.tld
# Shared secret — must match the value registered via:
#   occ talk:signaling:add "wss://talk.example.tld/" <secret> --verify
secret = REPLACE_WITH_SHARED_SECRET

# Optional: uncomment and fill if coturn is deployed
# [turn]
# # API key clients send to /api/v1/turn to get temporary TURN credentials
# apikey = REPLACE_WITH_TURN_APIKEY
# # Shared secret — must match coturn's --static-auth-secret
# secret = REPLACE_WITH_COTURN_SECRET
# servers = turn:talk.example.tld:3478?transport=udp,turn:talk.example.tld:3478?transport=tcp

[nats]
# NATS message broker — distributes messages across signaling nodes
url = nats://nats:4222
