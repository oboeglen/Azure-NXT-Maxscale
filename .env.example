# =============================================================================
# Azure NXT Maxscale — Variables d'environnement
# 1. Copiez ce fichier : cp .env.example .env
# 2. Remplissez TOUTES les valeurs marquées CHANGER
# 3. Ne commitez JAMAIS le fichier .env
# =============================================================================

COMPOSE_PROJECT_NAME=maxscale

# -----------------------------------------------------------------------------
# Domaines (DNS doit pointer vers ce serveur avant de générer les certificats)
# Pour un test local, utilisez : nextcloud.local / collabora.local / whiteboard.local
# et ajoutez à /etc/hosts (Linux) ou C:\Windows\System32\drivers\etc\hosts (Windows) :
#   127.0.0.1    nextcloud.local collabora.local whiteboard.local
# -----------------------------------------------------------------------------
NEXTCLOUD_DOMAIN=nextcloud.exemple.tld
COLLABORA_DOMAIN=collabora.exemple.tld
WHITEBOARD_DOMAIN=whiteboard.exemple.tld

# Email Let's Encrypt (notifications d'expiration de certificats)
CERTBOT_EMAIL=admin@exemple.tld

# Mot de passe page de statistiques HAProxy (http://<IP>:8404/stats)
HAPROXY_STATS_PASSWORD=CHANGER_MOT_DE_PASSE_STATS

# -----------------------------------------------------------------------------
# Nextcloud — Compte administrateur (créé automatiquement à l'installation)
# -----------------------------------------------------------------------------
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=CHANGER_MOT_DE_PASSE_ADMIN

# -----------------------------------------------------------------------------
# MariaDB Galera
# -----------------------------------------------------------------------------
MARIADB_ROOT_PASSWORD=CHANGER_MOT_DE_PASSE_ROOT
MARIADB_USER=nextcloud
MARIADB_PASSWORD=CHANGER_MOT_DE_PASSE_NEXTCLOUD_DB
MARIADB_DATABASE=nextcloud

# -----------------------------------------------------------------------------
# Redis Cluster (cache Nextcloud — 6 nœuds)
# -----------------------------------------------------------------------------
REDIS_PASSWORD=CHANGER_MOT_DE_PASSE_REDIS

# -----------------------------------------------------------------------------
# Redis Whiteboard (instance dédiée)
# -----------------------------------------------------------------------------
# ATTENTION : ne pas utiliser le caractère # dans ce mot de passe (interprété comme fragment d'URL par Node.js)
REDIS_WHITEBOARD_PASSWORD=CHANGER_MOT_DE_PASSE_REDIS_WHITEBOARD

# -----------------------------------------------------------------------------
# RustFS (stockage objet compatible S3) + bucket Nextcloud
# Le bucket est créé automatiquement par le service nextcloud-setup
# -----------------------------------------------------------------------------
RUSTFS_ACCESS_KEY=CHANGER_ACCESS_KEY_RUSTFS
RUSTFS_SECRET_KEY=CHANGER_SECRET_KEY_RUSTFS
NEXTCLOUD_S3_BUCKET=nextcloud

# -----------------------------------------------------------------------------
# RustFS — Chemins des disques sur l'hôte (bind mounts)
#
# Chaque nœud RustFS expose 4 drives (/data1 .. /data4).
# En production, chaque DATA{N} doit pointer vers un disque physique distinct
# pour que l'erasure coding soit effectif au niveau intra-nœud.
#
# Exemple : 4 nœuds × 4 disques = 16 disques physiques montés dans /mnt/
#   RUSTFS_NODE1_DATA1=/mnt/n1-disk1
#   RUSTFS_NODE1_DATA2=/mnt/n1-disk2
#   ...
#
# En test mono-serveur (valeurs par défaut) : tous les chemins tombent sur le
# même disque, l'erasure coding reste fonctionnel mais non-redondant physiquement.
#
# PATH = répertoire de métadonnées internes RustFS (peut être sur n'importe quel disque)
# -----------------------------------------------------------------------------

# Nœud 1
RUSTFS_NODE1_PATH=/data/rustfs/node1
RUSTFS_NODE1_DATA1=/data/rustfs/node1/data1
RUSTFS_NODE1_DATA2=/data/rustfs/node1/data2
RUSTFS_NODE1_DATA3=/data/rustfs/node1/data3
RUSTFS_NODE1_DATA4=/data/rustfs/node1/data4

# Nœud 2
RUSTFS_NODE2_PATH=/data/rustfs/node2
RUSTFS_NODE2_DATA1=/data/rustfs/node2/data1
RUSTFS_NODE2_DATA2=/data/rustfs/node2/data2
RUSTFS_NODE2_DATA3=/data/rustfs/node2/data3
RUSTFS_NODE2_DATA4=/data/rustfs/node2/data4

# Nœud 3
RUSTFS_NODE3_PATH=/data/rustfs/node3
RUSTFS_NODE3_DATA1=/data/rustfs/node3/data1
RUSTFS_NODE3_DATA2=/data/rustfs/node3/data2
RUSTFS_NODE3_DATA3=/data/rustfs/node3/data3
RUSTFS_NODE3_DATA4=/data/rustfs/node3/data4

# Nœud 4
RUSTFS_NODE4_PATH=/data/rustfs/node4
RUSTFS_NODE4_DATA1=/data/rustfs/node4/data1
RUSTFS_NODE4_DATA2=/data/rustfs/node4/data2
RUSTFS_NODE4_DATA3=/data/rustfs/node4/data3
RUSTFS_NODE4_DATA4=/data/rustfs/node4/data4

# -----------------------------------------------------------------------------
# Nextcloud Whiteboard
# -----------------------------------------------------------------------------
WHITEBOARD_JWT_SECRET=CHANGER_CLE_JWT_LONGUE_ET_ALEATOIRE_MIN_32_CHARS
